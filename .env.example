# ============================================================
# Variáveis de ambiente — exemplo
# Copie para um arquivo ".env" (local) ou configure no painel do Render.
# NUNCA suba o .env real para o GitHub (já está no .gitignore).
# ============================================================

# Banco de dados Postgres (Supabase). Se vazio, usa SQLite local (tuin.db).
# Pegue no Supabase: Project Settings > Database > Connection string (use o "Session Pooler" / IPv4).
# Ex: postgresql://postgres.xxxx:SUA_SENHA@aws-0-sa-east-1.pooler.supabase.com:5432/postgres
DATABASE_URL=

# Senha de acesso ao sistema (login). Se vazio, o sistema fica SEM senha (uso local).
# Em produção (online) DEFINA uma senha forte.
APP_SENHA=
APP_USUARIO=admin

# Porta (o Render define automaticamente; localmente pode deixar vazio = 3000)
PORT=
